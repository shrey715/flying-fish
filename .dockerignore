# .dockerignore - Files to exclude from Docker build context

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Jupyter Notebooks
.ipynb_checkpoints/
*.ipynb

# Git
.git/
.gitignore
.gitattributes

# Documentation
*.md
!README.md

# Logs (keep structure but not content)
logs/*.log

# Development files
uv.lock
.python-version

# Test files
tests/
test_*.py
*_test.py
